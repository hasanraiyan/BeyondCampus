generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum DegreeLevel {
  UG
  PG
  MBA
  PHD
}

enum IntakeSeason {
  FALL
  SPRING
  SUMMER
}

enum BudgetRange {
  UNDER_20K
  USD_20K_40K
  USD_40K_60K
  USD_60K_PLUS
}

enum ExamType {
  GRE
  GMAT
  IELTS
  TOEFL
  SAT
  ACT
}

enum ProfileFieldCategory {
  ACADEMIC
  TEST_SCORE
  PERSONAL
  IMMIGRATION
  FINANCIAL
}

enum ProfileFieldSource {
  AGENT
  MANUAL
}

enum DocumentType {
  TRANSCRIPT
  SOP
  LOR
  RESUME
  TEST_SCORE_REPORT
  PASSPORT
  FINANCIAL_PROOF
  PORTFOLIO
  OTHER
}

enum UniversityType {
  PUBLIC
  PRIVATE
}

enum ProgramDegreeType {
  BS
  MS
  MBA
  PHD
  ASSOCIATE
  CERTIFICATE
}

enum ShortlistTier {
  DREAM
  REACH
  SAFE
}

enum ApplicationStatus {
  DRAFT
  CHECKLIST_CREATED
  UPLOADING
  UNDER_REVIEW
  NEEDS_CORRECTION
  PACKET_COMPLETE
}

enum ChecklistItemType {
  DOCUMENT
  FORM
  TEST_SCORE
  OTHER
}

enum ChecklistItemStatus {
  PENDING
  UPLOADED
  APPROVED
  REJECTED
}

// ─── Auth & Student Identity ─────────────────────────────

model User {
  id                  String        @id @default(uuid())
  email               String        @unique
  password            String
  firstName           String
  lastName            String
  onboardingCompleted Boolean       @default(false)

  // Onboarding intent
  degreeLevel         DegreeLevel?
  fieldOfStudy        String?
  currentEducation    String?
  targetCountry       String?       @default("US")
  intakeSeason        IntakeSeason?
  intakeYear          Int?
  budgetRange         BudgetRange?
  hasGivenTests       Boolean?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations
  sessions            Session[]
  testScores          TestScore[]
  profileFields       ProfileField[]
  documents           Document[]
  shortlists          Shortlist[]
  applications        Application[]
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Student Profile (Dynamic) ───────────────────────────

model TestScore {
  id           String   @id @default(uuid())
  userId       String
  examType     ExamType
  overallScore Float
  subScores    Json?
  dateTaken    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, examType])
}

model ProfileField {
  id                String               @id @default(uuid())
  userId            String
  title             String
  value             String
  category          ProfileFieldCategory
  extractedBy       ProfileFieldSource   @default(MANUAL)
  sourceDocumentId  String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceDocument Document? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)

  @@index([userId, category])
}

// ─── Document Vault ──────────────────────────────────────

model Document {
  id        String       @id @default(uuid())
  userId    String
  type      DocumentType
  name      String
  fileName  String
  filePath  String
  mimeType  String
  fileSize  Int
  createdAt DateTime     @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileFields  ProfileField[]
  checklistItems ChecklistItem[]

  @@index([userId, type])
}

// ─── University Knowledge Base ───────────────────────────

model University {
  id             String         @id @default(uuid())
  name           String
  city           String
  state          String
  type           UniversityType
  ranking        Int?
  acceptanceRate Float?
  enrollmentSize Int?
  website        String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  programs     Program[]
  shortlists   Shortlist[]
  applications Application[]

  @@index([state])
}

model Program {
  id              String            @id @default(uuid())
  universityId    String
  name            String
  department      String?
  degreeType      ProgramDegreeType
  durationMonths  Int?
  tuitionPerYear  Float?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  university   University    @relation(fields: [universityId], references: [id], onDelete: Cascade)
  deadlines    Deadline[]
  shortlists   Shortlist[]
  applications Application[]

  @@index([universityId, degreeType])
}

model Deadline {
  id                  String   @id @default(uuid())
  programId           String
  roundName           String
  applicationDeadline DateTime
  decisionDate        DateTime?
  createdAt           DateTime @default(now())

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
}

// ─── Shortlist & Applications ────────────────────────────

model Shortlist {
  id           String        @id @default(uuid())
  userId       String
  universityId String
  programId    String?
  tier         ShortlistTier @default(REACH)
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  university University  @relation(fields: [universityId], references: [id], onDelete: Cascade)
  program    Program?    @relation(fields: [programId], references: [id], onDelete: SetNull)

  @@unique([userId, universityId, programId])
  @@index([userId])
}

model Application {
  id           String            @id @default(uuid())
  userId       String
  universityId String
  programId    String
  status       ApplicationStatus @default(DRAFT)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  completedAt  DateTime?

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  university     University      @relation(fields: [universityId], references: [id], onDelete: Cascade)
  program        Program         @relation(fields: [programId], references: [id], onDelete: Cascade)
  checklistItems ChecklistItem[]

  @@unique([userId, programId])
  @@index([userId, status])
}

model ChecklistItem {
  id            String              @id @default(uuid())
  applicationId String
  title         String
  description   String?
  type          ChecklistItemType
  status        ChecklistItemStatus @default(PENDING)
  feedback      String?
  documentId    String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  document    Document?   @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([applicationId, status])
}
