// Database connection
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Our main user table
model User {
  id                  String    @id @default(cuid())
  firstName           String
  lastName            String
  email               String    @unique
  password            String
  emailVerified       DateTime?
  onboardingCompleted Boolean   @default(false)
  nickname            String?
  currentEducation    String?
  targetCountries     String[]
  studyTimeline       String?
  preferredCourse     String?
  budget              String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  sessions Session[]
}

// NextAuth required tables
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum TwinStatus {
  TRAINING
  PUBLISHED
}

enum TwinSessionType {
  trainer
  chat
}

enum TwinSessionStatus {
  ACTIVE
  COMPLETED
  ERROR
}

model Twin {
  id           String     @id @default(uuid())
  user_id      String
  user_name    String
  twin_name    String
  tagline      String?
  personality  String?
  tone         String?
  links        Json       @default("[]")
  status       TwinStatus @default(TRAINING)
  public_url   String?    @unique
  created_at   DateTime   @default(now())
  published_at DateTime?

  sessions TwinSession[]
}

model TwinSession {
  id         String            @id @default(uuid())
  twin_id    String
  user_id    String?
  type       TwinSessionType
  notebook_id String?
  chapter_id String?
  thread_id  String?
  status     TwinSessionStatus @default(ACTIVE)
  metadata   Json?
  created_at DateTime          @default(now())
  ended_at   DateTime?

  twin Twin @relation(fields: [twin_id], references: [id], onDelete: Cascade)

  @@index([twin_id, created_at])
}