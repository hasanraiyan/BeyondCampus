# ===========================================
# BeyondCampus Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit .env with real secrets.

# Local PostgreSQL (docker compose defaults)
DATABASE_URL=postgresql://beyondcampus:beyondcampus@localhost:5433/beyondcampus
# Optional direct URL for Prisma migrate/CLI if you later use pooling
DIRECT_URL=postgresql://beyondcampus:beyondcampus@localhost:5433/beyondcampus

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# LangGraph Services (optional — needed for AI agents)
# TRAINER_SERVICE_URL=http://localhost:8000
# CHAT_SERVICE_URL=http://localhost:8001
# AI_SHARED_TOKEN=your-shared-token
